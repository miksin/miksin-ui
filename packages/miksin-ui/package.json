{
  "name": "miksin-ui",
  "version": "0.1.1",
  "description": "Token-based CSS design system",
  "repository": {
    "type": "git",
    "url": "https://github.com/miksin/miksin-ui.git"
  },
  "homepage": "https://github.com/miksin/miksin-ui#readme",
  "main": "./dist/miksin-ui.css",
  "exports": {
    ".": "./dist/miksin-ui.css",
