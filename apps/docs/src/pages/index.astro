---
import Layout from '../layouts/Layout.astro'
import CodeBlock from '../components/CodeBlock.astro'
---
<Layout title="Introduction">
  <h1 class="text-4xl font-bold mb-3">miksin-ui</h1>
  <p class="text-lg mb-8" style="color: var(--color-muted-fg);">
    A token-based CSS design system. Pure CSS classes that work with any JS framework.
    Tailwind-compatible.
  </p>

  <h2 class="text-2xl font-semibold mt-10 mb-4">Installation</h2>
  <CodeBlock code={`npm install miksin-ui`} />

  <h2 class="text-2xl font-semibold mt-10 mb-4">Usage — CSS import</h2>
  <p class="mb-3" style="color: var(--color-muted-fg);">Works with any framework. Import the CSS and use the classes directly.</p>
  <CodeBlock code={`import 'miksin-ui/dist/miksin-ui.css'`} />
  <CodeBlock code={`<button class="btn">Click me</button>`} />

  <h2 class="text-2xl font-semibold mt-10 mb-4">Usage — Tailwind v4</h2>
  <p class="mb-3" style="color: var(--color-muted-fg);">Import the CSS after Tailwind. Token utilities (<code>bg-primary</code>, <code>text-fg</code>, <code>rounded-base</code>, etc.) are generated automatically.</p>
  <CodeBlock code={`/* app.css */
@import "tailwindcss";
@import "miksin-ui/dist/miksin-ui.css";`} />

  <h2 class="text-2xl font-semibold mt-10 mb-4">Theming</h2>
  <p class="mb-3" style="color: var(--color-muted-fg);">Override CSS variables in your own stylesheet to set your brand colors.</p>
  <CodeBlock code={`:root {
  --color-primary-500: oklch(58% 0.22 145); /* green */
  --color-secondary-500: oklch(65% 0.18 260); /* blue */
  --radius-base: 0.5rem;                    /* less round */
}`} />
</Layout>
