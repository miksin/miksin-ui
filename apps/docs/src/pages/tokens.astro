---
import Layout from '../layouts/Layout.astro'

const tokens = [
  { name: '--color-primary-500', default: 'oklch(55% 0.2 250)', description: 'Primitive primary color (indigo)' },
  { name: '--color-neutral-50',  default: 'oklch(98% 0 0)',      description: 'Lightest neutral' },
  { name: '--color-neutral-900', default: 'oklch(15% 0 0)',      description: 'Darkest neutral' },
  { name: '--radius-base',       default: '0.375rem',            description: 'Base border radius' },
  { name: '--color-bg',          default: 'var(--color-neutral-50)',  description: 'Page background' },
  { name: '--color-fg',          default: 'var(--color-neutral-900)', description: 'Primary text' },
  { name: '--color-primary',     default: 'var(--color-primary-500)', description: 'Primary interactive color' },
  { name: '--color-primary-text',default: 'oklch(98% 0 0)',      description: 'Text on primary bg' },
  { name: '--color-border',      default: 'oklch(88% 0 0)',      description: 'Default border color' },
  { name: '--color-muted',       default: 'oklch(92% 0 0)',      description: 'Muted background' },
  { name: '--color-muted-fg',    default: 'oklch(45% 0 0)',      description: 'Muted text' },
  { name: '--btn-radius',        default: 'var(--radius-base)',  description: 'Button border radius' },
  { name: '--input-radius',      default: 'var(--radius-base)',  description: 'Input border radius' },
  { name: '--card-radius',       default: 'calc(var(--radius-base) * 2)', description: 'Card border radius' },
  { name: '--card-padding',      default: '1.5rem',              description: 'Card internal padding' },
]
---
<Layout title="Tokens">
  <h1 class="text-3xl font-bold mb-2">Design Tokens</h1>
  <p class="mb-8" style="color: var(--color-muted-fg);">
    Override any <code>:root</code> CSS variable to customise the theme.
    Component tokens (e.g. <code>--btn-radius</code>) are fine-grained overrides.
    Semantic tokens (e.g. <code>--color-primary</code>) affect all components at once.
  </p>

  <table class="w-full text-sm border-collapse">
    <thead>
      <tr style="border-bottom: 1.5px solid var(--color-border);">
        <th class="text-left py-2 pr-4">Token</th>
        <th class="text-left py-2 pr-4">Default</th>
        <th class="text-left py-2">Description</th>
      </tr>
    </thead>
    <tbody>
      {tokens.map(({ name, default: def, description }) => (
        <tr style="border-bottom: 1px solid var(--color-border); color: var(--color-muted-fg);">
          <td class="py-2 pr-4 font-mono text-xs" style="color: var(--color-fg);">{name}</td>
          <td class="py-2 pr-4 font-mono text-xs">{def}</td>
          <td class="py-2 text-xs">{description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Layout>
